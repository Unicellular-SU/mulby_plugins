{
  "id": "currency-converter",
  "name": "currency-converter",
  "version": "1.0.0",
  "author": "Mulby Team",
  "homepage": "https://github.com/mulby",
  "displayName": "人民币金额大写",
  "description": "将输入的数字金额转换为人民币大写形式",
  "main": "dist/main.js",
  "icon": "icon.png",
  "features": [
    {
      "code": "convert",
      "explain": "复制人民币大写",
      "cmds": [
        {
          "type": "regex",
          "match": "^\\s*\\d+(\\.\\d+)?\\s*$",
          "explain": "数字转大写"
        }
      ]
    }
  ]
}
