{
  "id": "image_stitching",
  "name": "image_stitching",
  "version": "1.0.0",
  "author": "Mulby",
  "homepage": "https://github.com/Unicellular-SU/mulby_plugins",
  "displayName": "长图拼接",
  "description": "将多张图片任意纵向裁切后拼接成一张长图",
  "main": "dist/main.js",
  "ui": "ui/index.html",
  "icon": "icon.png",
  "features": [
    {
      "code": "image_stitching",
      "explain": "长图拼接 - 将多张图片任意纵向裁切后拼接成一张长图",
      "icon": "🖼️",
      "mode": "ui",
      "route": "/stitch",
      "mainHide": false,
      "mainPush": true,
      "cmds": [
        {
          "type": "keyword",
          "value": "图片拼接",
          "explain": "长图拼接功能"
        },
        {
          "type": "keyword",
          "value": "image stitch",
          "explain": "Image stitching function"
        },
        {
          "type": "img",
          "exts": ["png", "jpg", "jpeg", "gif", "webp", "bmp"]
        }
      ]
    }
  ]
