{
  "id": "@mulby/encoding-converter",
  "name": "encoding-converter",
  "version": "1.0.0",
  "author": "Mulby",
  "homepage": "https://github.com/Unicellular-SU/mulby_plugins",
  "displayName": "Encoding Converter",
  "description": "Text encoding converter (UTF-8, GBK), Base64/Hex transport, URL encoding, and Huffman compression visualizer.",
  "main": "dist/main.js",
  "ui": "ui/index.html",
  "icon": "icon.png",
  "features": [
    {
      "code": "main",
      "explain": "Encoding Converter",
      "cmds": [
        {
          "type": "keyword",
          "value": "encode"
        },
        {
          "type": "keyword",
          "value": "decode"
        },
        {
          "type": "keyword",
          "value": "base64"
        },
        {
          "type": "keyword",
          "value": "url"
        },
        {
          "type": "keyword",
          "value": "huffman"
        },
        {
          "type": "keyword",
          "value": "gbk"
        }
      ]
    }
  ]
}
