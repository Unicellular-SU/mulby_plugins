{
  "id": "pdf-tools",
  "name": "pdf-tools",
  "version": "1.0.0",
  "displayName": "PDF 拆分工具",
  "description": "将PDF文件按页面拆分为多个独立文档，支持自动拆分和手动拆分",
  "main": "dist/main.js",
  "ui": "ui/index.html",
  "preload": "preload.cjs",
  "icon": "icon.png",
  "window": {
    "width": 800,
    "height": 600
  },
  "features": [
    {
      "code": "split",
      "explain": "拆分PDF文件",
      "cmds": [
        {
          "type": "keyword",
          "value": "pdf拆分"
        },
        {
          "type": "files",
          "exts": [
            ".pdf"
          ],
          "minLength": 1,
          "maxLength": 1
        }
      ]
    }
  ]
}