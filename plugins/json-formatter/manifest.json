        }
      ]
    },
    {
      "code": "minify",
      "explain": "压缩 JSON",
      "cmds": [
        {
          "type": "keyword",
          "value": "json压缩"
        },
        {
          "type": "keyword",
          "value": "json minify"
        },
        {
          "type": "regex",
          "match": "^\\s*[{\\[]",
          "explain": "检测到 JSON"
        }
      ]
    }
  ]
}
