{
  "id": "@mulby/showcase",
  "name": "mulby-showcase",
  "version": "1.0.0",
  "displayName": "Mulby 功能展示",
  "description": "综合展示 Mulby 所有 API 能力的示例插件，涵盖系统信息、剪贴板、文件管理、网络、屏幕捕获、媒体、高级设置和安全存储等功能",
  "main": "dist/main.js",
  "ui": "ui/index.html",
  "icon": "icon.png",
  "author": "Mulby Team",
  "homepage": "https://github.com/mulby",
  "minAppVersion": "1.0.0",
  "features": [
    {
      "code": "main",
      "explain": "打开功能展示面板",
      "cmds": [
        {
          "type": "keyword",
          "value": "showcase"
        },
        {
          "type": "keyword",
          "value": "demo"
        },
        {
          "type": "keyword",
          "value": "示例"
        },
        {
          "type": "keyword",
          "value": "功能展示"
        }
      ]
    },
    {
      "code": "screenshot",
      "explain": "区域截图并进入图片编辑",
      "cmds": [
        {
          "type": "keyword",
          "value": "sc"
        },
        {
          "type": "keyword",
          "value": "截图"
        },
        {
          "type": "keyword",
          "value": "screenshot"
        }
      ]
    },
    {
      "code": "sysinfo",
      "explain": "查看系统信息",
      "cmds": [
        {
          "type": "keyword",
          "value": "sysinfo"
        },
        {
          "type": "keyword",
          "value": "系统信息"
        }
      ]
    },
    {
      "code": "clipboard",
      "explain": "剪贴板管理",
      "cmds": [
        {
          "type": "keyword",
          "value": "cb"
        },
        {
          "type": "keyword",
          "value": "剪贴板"
        }
      ]
    },
    {
      "code": "input",
      "explain": "输入控制示例",
      "cmds": [
        {
          "type": "keyword",
          "value": "input"
        },
        {
          "type": "keyword",
          "value": "输入"
        }
      ]
    },
    {
      "code": "files",
      "explain": "文件管理",
      "cmds": [
        {
          "type": "keyword",
          "value": "files"
        },
        {
          "type": "keyword",
          "value": "文件"
        }
      ]
    },
    {
      "code": "network",
      "explain": "网络与HTTP测试",
      "cmds": [
        {
          "type": "keyword",
          "value": "http"
        },
        {
          "type": "keyword",
          "value": "网络"
        }
      ]
    },
    {
      "code": "screen",
      "explain": "屏幕截图与显示器信息",
      "cmds": [
        {
          "type": "keyword",
          "value": "screenshot"
        },
        {
          "type": "keyword",
          "value": "截图"
        },
        {
          "type": "keyword",
          "value": "screen"
        }
      ]
    },
    {
      "code": "media",
      "explain": "媒体与语音合成",
      "cmds": [
        {
          "type": "keyword",
          "value": "tts"
        },
        {
          "type": "keyword",
          "value": "语音"
        },
        {
          "type": "keyword",
          "value": "朗读"
        }
      ]
    },
    {
      "code": "settings",
      "explain": "高级设置",
      "cmds": [
        {
          "type": "keyword",
          "value": "settings"
        },
        {
          "type": "keyword",
          "value": "设置"
        }
      ]
    },
    {
      "code": "attachments",
      "explain": "附件接收展示",
      "cmds": [
        {
          "type": "keyword",
          "value": "attachments"
        },
        {
          "type": "keyword",
          "value": "附件"
        }
      ]
    }
  ]
}
